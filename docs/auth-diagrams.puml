' ============================================================
' Learning-Graph 认证模块 UML 图集合
' 包含：用例图、顺序图、类图、状态图
' ============================================================

' ============================================================
' 一、用例图 (Use Case Diagram)
' ============================================================
@startuml 用例图-注册与登录
title 注册与登录功能用例图

left to right direction

actor "普通用户" as User <<用户>>
actor "管理员" as Admin <<管理员, extends 普通用户>>
actor "JWT 认证系统" as System <<系统>>

rectangle "注册与登录模块" {

  ' 注册相关
  usecase "注册账号" as UC_Register
  usecase "输入用户名/邮箱/密码" as UC_InputReg
  usecase "验证用户名唯一性" as UC_CheckDup
  usecase "密码加密存储" as UC_EncryptPwd

  ' 登录相关
  usecase "登录系统" as UC_Login
  usecase "输入用户名/密码" as UC_InputLogin
  usecase "验证凭据" as UC_VerifyCred
  usecase "生成 JWT Token" as UC_GenJWT
  usecase "返回令牌和用户信息" as UC_ReturnToken

  ' 认证后访问
  usecase "访问受保护资源" as UC_AccessProtected
  usecase "获取当前用户信息 (/auth/me)" as UC_GetMe
  usecase "携带 Bearer Token 请求" as UC_BearerToken
  usecase "JWT 过滤器校验令牌" as UC_FilterCheck
  usecase "令牌过期/无效返回 401" as UC_401

  ' 管理员专属
  usecase "访问管理后台 (/admin/**)" as UC_AdminAccess
  usecase "管理系统数据" as UC_AdminManage
}

' 用户关系
User --> UC_Register
User --> UC_Login
User --> UC_AccessProtected
User --> UC_GetMe

UC_Register ..> UC_InputReg : <<include>>
UC_Register ..> UC_CheckDup : <<include>>
UC_Register ..> UC_EncryptPwd : <<include>>
UC_Register ..> UC_GenJWT : <<include>>

UC_Login ..> UC_InputLogin : <<include>>
UC_Login ..> UC_VerifyCred : <<include>>
UC_Login ..> UC_GenJWT : <<include>>
UC_Login ..> UC_ReturnToken : <<include>>

UC_AccessProtected ..> UC_BearerToken : <<include>>
UC_BearerToken ..> UC_FilterCheck : <<include>>
UC_FilterCheck ..> UC_401 : <<extends>>

' 管理员关系
Admin --|> User
Admin --> UC_AdminAccess
Admin --> UC_AdminManage

UC_AdminAccess ..> UC_BearerToken : <<include>>
UC_AdminAccess ..> UC_FilterCheck : <<include>>

@enduml


' ============================================================
' 二、顺序图 1：注册流程
' ============================================================
@startuml 顺序图-注册流程
title 用户注册顺序图 (Register)

actor "用户" as User
participant "RegisterView\n(Vue前端)" as Frontend
participant "AuthController" as Controller
participant "AuthServiceImpl" as Service
participant "UserMapper\n(MyBatis-Plus)" as Mapper
database "MySQL\n(lgraph_user)" as DB
participant "JwtTokenProvider" as JWT

== 用户填写注册表单 ==
User -> Frontend: 输入用户名/邮箱/密码/确认密码
Frontend -> Frontend: 前端表单校验\n(格式、密码一致性)

== 提交注册请求 ==
User -> Frontend: 点击"注册"按钮
Frontend -> Controller: POST /auth/register\n{ username, email, password }
Controller -> Controller: @Valid 校验请求体

== 业务逻辑处理 ==
Controller -> Service: register(request)
Service -> Mapper: selectOne(username)
Mapper -> DB: SELECT * FROM lgraph_user\nWHERE username = ?
DB --> Mapper: null (不存在)
Mapper --> Service: null

Service -> Mapper: selectOne(email)
Mapper -> DB: SELECT * FROM lgraph_user\nWHERE email = ?
DB --> Mapper: null (不存在)
Mapper --> Service: null

Service -> Service: passwordEncoder.encode(password)\n→ BCrypt hash
Service -> Service: new User()\n.setRole(UserRole.USER)\n← 仅允许注册为普通用户

Service -> Mapper: insert(user)
Mapper -> DB: INSERT INTO lgraph_user\n(username, email, password_hash, role)
DB --> Mapper: affected rows = 1
note right: MyBatis-Plus @TableId(IdType.AUTO)\n自动回填 user.id

== 生成 JWT ==
Service -> JWT: generateToken(userId, username, "USER")
JWT -> JWT: Jwts.builder()\n.subject(userId)\n.claim("username", ...)\n.claim("role", "USER")\n.signWith(hmacKey)
JWT --> Service: token (JWT string)

== 返回结果 ==
Service --> Controller: LoginResponse(token, UserDto)
Controller --> Frontend: ApiResponse(200, LoginResponse)
Frontend -> Frontend: localStorage.setItem('token', token)\nrouter.push('/subjects')
Frontend --> User: 页面跳转至学科列表

@enduml


' ============================================================
' 二、顺序图 2：普通用户登录流程
' ============================================================
@startuml 顺序图-普通用户登录
title 普通用户登录顺序图 (Login - USER)

actor "普通用户" as User
participant "LoginView\n(Vue前端)" as Frontend
participant "AuthController" as Controller
participant "AuthServiceImpl" as Service
participant "UserMapper" as Mapper
database "MySQL" as DB
participant "JwtTokenProvider" as JWT
participant "JwtAuthenticationFilter" as Filter
participant "SecurityConfig" as SecConfig

== 用户输入凭据 ==
User -> Frontend: 输入用户名/密码
Frontend -> Frontend: 表单校验非空

== 登录请求 ==
User -> Frontend: 点击"登录"
Frontend -> Controller: POST /auth/login\n{ username, password }
note right: SecurityConfig 放行\n.requestMatchers("/auth/**").permitAll()

Controller -> Service: login(request)

== 验证用户 ==
Service -> Mapper: selectOne(username)
Mapper -> DB: SELECT * FROM lgraph_user\nWHERE username = ?
DB --> Mapper: user row (role=USER)
Mapper --> Service: User(id, username, passwordHash, role=USER)

Service -> Service: passwordEncoder.matches(password, passwordHash)
note right: BCrypt 比对明文与密文
Service --> Service: true (匹配)

== 生成 JWT ==
Service -> JWT: generateToken(userId, username, "USER")
JWT -> JWT: 构建 JWT claims:\nsub=userId, role=USER,\nexp=now+7d
JWT --> Service: token

== 返回 ==
Service --> Controller: LoginResponse(token, UserDto)
Controller --> Frontend: ApiResponse(200, { token, user })
Frontend -> Frontend: authStore.setAuth(token, user)\nlocalStorage.setItem('token', token)
Frontend -> Frontend: router.push('/subjects')

== 后续请求认证 ==
User -> Frontend: 访问学科列表
Frontend -> Filter: GET /api/v1/subjects\nAuthorization: Bearer <token>
Filter -> JWT: validateToken(token)
JWT --> Filter: true (有效)
Filter -> JWT: getUserId(token) / getUsername(token)
Filter -> Filter: 构建 AuthenticationToken\n.authorities(ROLE_USER)\n存入 SecurityContextHolder
Filter -> SecConfig: filterChain.doFilter()\n→ 请求通过

@enduml


' ============================================================
' 二、顺序图 3：管理员登录与鉴权
' ============================================================
@startuml 顺序图-管理员登录与鉴权
title 管理员登录与访问控制顺序图 (Login - ADMIN)

actor "管理员" as Admin
participant "前端" as Frontend
participant "AuthController" as Controller
participant "AuthServiceImpl" as Service
participant "JwtTokenProvider" as JWT
participant "JwtAuthenticationFilter" as Filter
participant "SecurityConfig" as SecConfig
participant "AdminController" as AdminCtrl

== 管理员登录（与普通用户相同流程） ==
Admin -> Frontend: 输入管理员账号/密码
Frontend -> Controller: POST /auth/login
Controller -> Service: login(request)
Service -> Service: 验证用户 → 用户 role=ADMIN
Service -> JWT: generateToken(userId, username, "ADMIN")
JWT --> Service: token (role=ADMIN)
Service --> Controller: LoginResponse(token, UserDto(role=ADMIN))
Controller --> Frontend: token + user
Frontend -> Frontend: authStore.setAuth(token, user)\nlocalStorage.setItem('token', token)

== 管理员访问管理后台 ==
Admin -> Frontend: 点击管理后台
Frontend -> AdminCtrl: GET /admin/stats\nAuthorization: Bearer <token>

group JWT 过滤器鉴权
  Filter -> JWT: validateToken(token) → true
  Filter -> Filter: 提取 role=ADMIN\n构建 authorities=[ROLE_ADMIN]\n存入 SecurityContext
end

group Spring Security 方法级鉴权
  SecConfig -> SecConfig: .requestMatchers("/admin/**")\n.hasRole("ADMIN")
  note right: 检查 authorities 中\n是否包含 ROLE_ADMIN
  SecConfig --> AdminCtrl: 允许访问 ✓
end

AdminCtrl --> Frontend: ApiResponse(200, AdminStats)
Frontend --> Admin: 显示管理后台数据

== 普通用户尝试访问管理后台（被拒绝） ==
note over Admin, AdminCtrl: 如果 token 中 role=USER
Filter -> Filter: authorities=[ROLE_USER]
SecConfig -> SecConfig: .hasRole("ADMIN") → 失败
SecConfig --> Frontend: HTTP 403 Forbidden

@enduml


' ============================================================
' 三、类图 (Class Diagram) — 中英双语版
' ============================================================
@startuml 类图-认证模块
title 注册与登录功能类图 (中英双语)

' -- 实体层 / Entity Layer --
class "用户 User" as User {
  - Long id
  - String username 用户名
  - String passwordHash 密码哈希
  - String email 邮箱
  - UserRole role 角色
  - String avatarUrl 头像
  - Integer deleted 逻辑删除
  - LocalDateTime createdAt 创建时间
  - LocalDateTime updatedAt 更新时间
}

enum "用户角色 UserRole" as UserRole {
  USER 普通用户
  ADMIN 管理员
}

User "1" *-- "1" UserRole

' -- DTO 层 / DTO Layer --
class "登录请求 LoginRequest" as LoginRequest {
  - String username 用户名
  - String password 密码
}

class "注册请求 RegisterRequest" as RegisterRequest {
  - String username 用户名
  - String email 邮箱
  - String password 密码
}

class "登录响应 LoginResponse" as LoginResponse {
  - String token 令牌
  - UserDto user 用户信息
}

class "用户DTO UserDto" as UserDto {
  - Long id
  - String username 用户名
  - String email 邮箱
  - String role 角色
  - String avatarUrl 头像
  - String createdAt 创建时间
  + static from(User) : UserDto 工厂方法
}

class "统一响应 ApiResponse<T>" as ApiResponse {
  - int code 状态码
  - String message 消息
  - T data 数据
  - long timestamp 时间戳
  + static success(T) : ApiResponse<T>
  + static error(int, String) : ApiResponse<T>
}

LoginResponse *-- "1" UserDto

' -- Controller 层 / Controller Layer --
class "认证控制器 AuthController" as AuthController {
  - AuthService authService 认证服务
  + login(LoginRequest) : ApiResponse<LoginResponse>\n用户登录
  + register(RegisterRequest) : ApiResponse<LoginResponse>\n用户注册
  + me() : ApiResponse<UserDto>\n获取当前用户
}

' -- Service 层 / Service Layer --
interface "认证服务接口 AuthService" as AuthService {
  + login(LoginRequest) : LoginResponse\n用户登录
  + register(RegisterRequest) : LoginResponse\n用户注册
  + getCurrentUser(Long) : UserDto\n获取当前用户
}

class "认证服务实现 AuthServiceImpl" as AuthServiceImpl {
  - UserMapper userMapper 用户映射器
  - PasswordEncoder passwordEncoder 密码编码器
  - JwtTokenProvider tokenProvider JWT提供者
  + login(LoginRequest) : LoginResponse\n用户登录
  + register(RegisterRequest) : LoginResponse\n用户注册
  + getCurrentUser(Long) : UserDto\n获取当前用户
}

' -- 安全组件 / Security Components --
class "JWT令牌提供者 JwtTokenProvider" as JwtTokenProvider {
  - SecretKey key 密钥
  - long expirationMs 过期毫秒
  + generateToken(Long, String, String) : String\n生成JWT
  + parseToken(String) : Claims\n解析JWT
  + validateToken(String) : boolean\n校验JWT有效性
  + getUserId(String) : Long\n提取用户ID
  + getUsername(String) : String\n提取用户名
}

class "JWT认证过滤器 JwtAuthenticationFilter" as JwtAuthenticationFilter {
  - JwtTokenProvider tokenProvider JWT提供者
  - UserDetailsServiceImpl userDetailsService 用户详情服务
  + doFilterInternal(Request, Response, FilterChain)\n过滤请求并设置认证上下文
  - extractToken(HttpServletRequest) : String\n从Header提取Bearer Token
}

class "用户详情服务 UserDetailsServiceImpl" as UserDetailsServiceImpl {
  - UserMapper userMapper 用户映射器
  + loadUserByUsername(String) : UserDetails\n按用户名加载
  + loadUserById(Long) : User\n按ID加载
}

class "安全工具类 SecurityUtils" as SecurityUtils {
  {static} + getCurrentUserId() : Long\n获取当前登录用户ID
  {static} + getCurrentUser() : User\n获取当前登录用户完整信息
}

class "安全配置 SecurityConfig" as SecurityConfig {
  - JwtAuthenticationFilter jwtAuthFilter JWT过滤器
  + filterChain(HttpSecurity) : SecurityFilterChain\n配置安全过滤链
  + passwordEncoder() : PasswordEncoder\nBCrypt密码编码器
  + authenticationManager() : AuthenticationManager\n认证管理器
}

class "业务异常 BusinessException" as BusinessException {
  - int code 业务错误码
  + BusinessException(int, String)\n构造方法
  + BusinessException(String)\n默认400
}

' -- 持久层 / Persistence Layer --
interface "用户映射器 UserMapper\n(MyBatis-Plus BaseMapper)" as UserMapper {
  + selectOne(Wrapper) : User\n按条件查询单个
  + selectById(Long) : User\n按ID查询
  + insert(User) : int\n插入用户记录
}

' -- 关系 / Relationships --
AuthController --> AuthService : 依赖
AuthService <|.. AuthServiceImpl : 实现

AuthServiceImpl --> UserMapper : 调用数据访问
AuthServiceImpl --> PasswordEncoder : 密码编码
AuthServiceImpl --> JwtTokenProvider : 生成JWT
AuthServiceImpl ..> User : 创建实体
AuthServiceImpl ..> LoginResponse : 返回
AuthServiceImpl ..> UserDto : 返回
AuthServiceImpl ..> BusinessException : 业务异常

AuthController ..> ApiResponse : 统一响应
AuthController ..> SecurityUtils : 获取当前用户

JwtAuthenticationFilter --> JwtTokenProvider : 校验/解析JWT
JwtAuthenticationFilter --> UserDetailsServiceImpl : 加载用户详情
JwtAuthenticationFilter ..> SecurityContextHolder : 写入认证上下文
UserDetailsServiceImpl --> UserMapper : 数据查询
SecurityConfig --> JwtAuthenticationFilter : 注册到过滤链

UserMapper ..> User : 映射 lgraph_user 表
User --> UserRole : 枚举角色

@enduml


' ============================================================
' 四、状态图 (State Diagram)
' ============================================================
@startuml 状态图-用户认证状态
title 用户认证状态图 (Authentication State Machine)

[*] --> 未登录 : 初始状态

state 未登录 {
  [*] --> 停留在登录页
  停留在登录页 : 显示登录/注册表单
}

未登录 --> 注册中 : 用户点击注册\n填写注册表单

state 注册中 {
  [*] --> 提交注册信息
  提交注册信息 : POST /auth/register
  提交注册信息 --> 校验用户名唯一性
  校验用户名唯一性 --> 校验邮箱唯一性 : 通过
  校验用户名唯一性 --> 注册失败 : 用户名已存在
  校验邮箱唯一性 --> 密码加密 : 通过
  校验邮箱唯一性 --> 注册失败 : 邮箱已被注册
  密码加密 --> 创建用户记录 : BCrypt hash
  创建用户记录 --> 生成JWT : UserRole=USER
  注册失败 --> 停留在注册页 : 显示错误信息
  生成JWT --> 注册成功
}

注册中 --> 已登录(普通用户) : 注册成功
注册中 --> 未登录 : 注册失败

未登录 --> 登录中 : 用户点击登录\n输入凭据

state 登录中 {
  [*] --> 提交凭据
  提交凭据 : POST /auth/login
  提交凭据 --> 查询用户
  查询用户 --> 密码比对
  密码比对 --> 生成JWT : 密码正确
  密码比对 --> 登录失败 : 密码错误
  查询用户 --> 登录失败 : 用户不存在
  登录失败 --> 停留在登录页 : 显示"用户名或密码错误"
  生成JWT --> 登录成功
}

登录中 --> 已登录(普通用户) : 登录成功 (role=USER)
登录中 --> 已登录(管理员) : 登录成功 (role=ADMIN)
登录中 --> 未登录 : 登录失败

state "已登录(普通用户)" as LoggedInUser {
  [*] --> 持有JWT_TOKEN
  持有JWT_TOKEN : token 存储在\nlocalStorage
  持有JWT_TOKEN --> 访问受保护资源 : 携带 Bearer Token
  访问受保护资源 --> 请求通过 : JWT 有效 + role=USER
  访问受保护资源 --> Token过期 : JWT 过期
  Token过期 --> [*] : 返回 401

  访问受保护资源 --> 访问管理员接口 : 尝试 /admin/**
  访问管理员接口 --> 拒绝访问 : SecurityConfig\n.hasRole("ADMIN") 检查失败
  拒绝访问 : HTTP 403 Forbidden
  拒绝访问 --> [*] : 返回 403

  state 会话管理 {
    正常请求 : 每次请求经过\nJwtAuthenticationFilter
    令牌刷新 : 过期前需重新登录
  }
}

state "已登录(管理员)" as LoggedInAdmin {
  [*] --> 持有JWT_TOKEN_ADMIN
  持有JWT_TOKEN_ADMIN : token.role = ADMIN
  持有JWT_TOKEN_ADMIN --> 访问普通资源 : 通过 (ROLE_ADMIN ⊇ USER)
  持有JWT_TOKEN_ADMIN --> 访问管理员接口 : 通过 .hasRole("ADMIN") ✓
  持有JWT_TOKEN_ADMIN --> 访问管理后台 : /admin/**
  访问管理后台 --> 管理数据 : 用户管理、学科管理等
  持有JWT_TOKEN_ADMIN --> Token过期 : JWT 过期
  Token过期 --> [*] : 返回 401
}

LoggedInUser --> 未登录 : 主动退出登录\nlocalStorage.removeItem('token')
LoggedInAdmin --> 未登录 : 主动退出登录

note right of LoggedInUser
  普通用户只能注册为 USER
  管理员账号由系统预置
  或数据库直接修改 role
end note

note bottom of 登录中
  JWT 包含:
  - sub: userId
  - username
  - role: USER | ADMIN
  - exp: 过期时间 (7天)
end note

@enduml


' ============================================================
' 五、界面跳转交互图 (Page Navigation Sequence Diagram)
' ============================================================
@startuml 交互图-界面跳转
title 界面跳转交互图\n(注册 → 登录 → 学科列表 → 学科详情 → 图谱/进度/幻灯片)

actor "用户" as User
participant "路由守卫\nsetupGuards" as Guard
participant "App.vue\n布局分发" as App
box "布局组件" #LightYellow
  participant "AuthLayout\n(登录/注册)" as AuthLayout
  participant "MainLayout\n(主界面)" as MainLayout
end box
box "视图组件" #LightCyan
  participant "LoginView" as Login
  participant "RegisterView" as Register
  participant "SubjectListView\n我的学科" as SubjectList
  participant "SubjectDetailView\n学科详情" as SubjectDetail
  participant "GraphExplorerView\n知识图谱" as Graph
  participant "ReviewProgressView\n学习进度" as Review
  participant "SlideShowView\n演示模式" as Slide
  participant "NoteEditorView\n(自动跳转)" as NoteEditor
  participant "PageEditorView\n页面编辑器" as PageEditor
  participant "AdminDashboard\n管理后台" as Admin
  participant "ForbiddenView\n403" as Forbidden
end box
participant "AppSidebar\n侧边栏" as Sidebar
participant "AppNavbar\n导航栏/标签" as Navbar
participant "KnowledgeTree\n知识树" as Tree

== 1. 注册流程 ==
User -> Register: 访问 /register
Guard --> Register: meta.guest ✓

User -> Register: 填写注册表单并提交
Register -> Register: RegisterView.onSubmit()\n→ authStore.register()
Register --> User: 注册成功，ElMessage 提示
Register -> App: router.push('/subjects')

== 2. 登录流程 ==
User -> Login: 访问 /login
Guard --> Login: meta.guest ✓

User -> Login: 输入凭据并点击登录
Login -> Login: LoginView.onSubmit()\n→ authStore.login()
Login --> User: 登录成功
Login -> App: router.push('/subjects')\n或 redirect query 参数

== 3. 进入学科列表 ==
App -> MainLayout: meta.layout = 'main'
MainLayout -> Sidebar: 渲染侧边栏
Sidebar -> Sidebar: onMounted → fetchSubjects()
Sidebar -> Sidebar: watch(route.params.subjectId)\n→ syncFromRoute()
MainLayout -> Navbar: 渲染导航栏（面包屑）
MainLayout -> SubjectList: 渲染 <router-view />
SubjectList -> SubjectList: onMounted → fetchSubjects()
SubjectList --> User: 显示学科卡片网格

== 4. 点击学科卡片进入详情 ==
User -> SubjectList: 点击某学科卡片
SubjectList -> SubjectList: enterSubject(id)
SubjectList -> App: router.push('/subjects/:id')
App -> SubjectDetail: 路由匹配 SubjectDetailView
SubjectDetail -> SubjectDetail: onMounted → fetchNote(subjectId)\n加载笔记页列表 + MarkdownEditor

Navbar -> Navbar: 面包屑显示学科名
Sidebar -> Sidebar: syncFromRoute() →\n更新下拉框 + 加载知识树
Sidebar -> Tree: treeStore.fetchTree(id)
Tree --> Sidebar: 渲染知识树

== 5. 点击知识树节点 ==
User -> Sidebar: 点击知识树某个节点
Sidebar -> Tree: onNodeClick(nodeId)\n→ treeStore.selectNode + expandNode
Navbar -> Navbar: 面包屑追加节点名
Tree --> User: 节点高亮 + 展开

== 6. 导航栏切换视图模式 ==
User -> Navbar: 点击"图谱"
Navbar -> Navbar: onTabClick('graph')
Navbar -> App: router.push('/subjects/:id/graph')
App -> Graph: 渲染 GraphExplorerView
Graph -> Graph: onMounted → fetchGraphData(subjectId)
Graph --> User: 显示知识图谱

User -> Navbar: 点击"进度"
Navbar -> Navbar: onTabClick('progress')
Navbar -> App: router.push('/review/:id')
App -> Review: 渲染 ReviewProgressView
Review -> Review: onMounted → fetchProgress + fetchNote
Review --> User: 显示学习进度统计

User -> Navbar: 点击"演示"
Navbar -> Navbar: onTabClick('slides')
Navbar -> App: router.push('/subjects/:id/slides')
App -> Slide: 渲染 SlideShowView (layout=blank)
Slide --> User: 全屏演示模式

User -> Navbar: 点击"编辑"
Navbar -> Navbar: onTabClick('edit')
Navbar -> App: router.push('/subjects/:id')
App -> SubjectDetail: 回到学科详情页

== 7. 图谱/进度页返回 ==
User -> Graph: 点击"← 返回"
Graph -> App: router.push('/subjects/:id')
App -> SubjectDetail: 回到学科详情

== 8. 返回学科列表（面包屑 HomeFilled） ==
User -> Navbar: 点击面包屑 HomeFilled 图标
Navbar -> App: router.push('/subjects')
App -> SubjectList: 渲染学科列表
Sidebar -> Sidebar: syncFromRoute() →\n清除选中 + 清除知识树
Navbar -> Navbar: 面包屑仅显示首页图标

== 9. 管理员路径 ==
User -> Navbar: 点击管理后台图标
Navbar -> App: router.push('/admin')
Guard -> App: meta.requiresAdmin →\n检查 authStore.isAdmin

alt 角色 == ADMIN
  App -> Admin: 渲染 AdminDashboard
else 角色 == USER
  Guard -> App: next({ name: 'Forbidden' })
  App -> Forbidden: 显示 403 页面
end

@enduml


' ============================================================
' 六、界面跳转类图 (Page Navigation Class Diagram)
' ============================================================
@startuml 类图-界面跳转
title 界面跳转类图\n(路由 → 布局 → 视图 → 组件 → Store)

' -- 路由层 --
class "Vue Router\ncreateRouter(history, routes)" as Router {
  + beforeEach(guard)
  + scrollBehavior()
}

class "路由守卫 setupGuards\n(router/guards.ts)" as Guards {
  + beforeEach(to, from, next)
  __ 检查 authStore.isAuthenticated
  __ 检查 authStore.isAdmin
  __ 检查 meta.requiresAuth / guest / requiresAdmin
}

class "路由配置 routes[]\n(router/routes.ts)" as RoutesConfig {
  + path: '/login' → LoginView (layout: auth, guest)
  + path: '/register' → RegisterView (layout: auth, guest)
  + path: '/subjects' → SubjectListView (layout: main, requiresAuth)
  + path: '/subjects/:subjectId' → SubjectDetailView (layout: main, requiresAuth)
  + path: '/subjects/:subjectId/graph' → GraphExplorerView (layout: main, requiresAuth)
  + path: '/review/:subjectId' → ReviewProgressView (layout: main, requiresAuth)
  + path: '/subjects/:subjectId/slides' → SlideShowView (layout: blank, requiresAuth)
  + path: '/subjects/:subjectId/notes/:noteId' → NoteEditorView (layout: main, requiresAuth)
  + path: '/subjects/:subjectId/pages/:pageId' → PageEditorView (layout: main, requiresAuth)
  + path: '/admin' → AdminLayout (requiresAdmin)
  + path: '/403' → ForbiddenView (layout: blank)
  + path: '/*' → NotFoundView (layout: blank)
}

' -- 布局层 --
class "App.vue\n布局分发器" as AppVue {
  - layoutMap: { main, auth }
  + layoutComponent : computed
  __ 根据 route.meta.layout 动态切换
  + <router-view> 嵌套路由出口
}

class "AuthLayout\n认证页布局" as AuthLayout {
  __ 居中卡片式布局
  __ 无侧栏、无导航栏
  + <router-view> 渲染 LoginView / RegisterView
}

class "MainLayout\n主界面布局" as MainLayout {
  - uiStore 界面状态
  - noteStore 笔记状态
  - pageStore 页面状态
  + sidebarWidth : computed(64px / 280px)
  + pageCount : computed
  + statusText : computed (已保存/未保存/保存中)
  + statusClass : computed
  __ 三栏布局: 侧栏 + 中心 + 右面板
  + <AppSidebar> 左侧知识树
  + <AppNavbar> 顶部导航
  + <router-view> 内容区
  + <RightPanel> 右侧面板(可收拢)
}

class "BlankLayout\n全屏布局(隐式)" as BlankLayout {
  __ 无导航、无侧栏
  __ 演示模式 / 错误页使用
}

' -- 视图层 --
class "LoginView\n登录页" as LoginView {
  - form: { username, password }
  - rules: FormRules 表单校验
  + onSubmit() → authStore.login()
  __ 成功后 router.push(redirect || '/subjects')
  __ ElMessage.success('登录成功')
}

class "RegisterView\n注册页" as RegisterView {
  - form: { username, email, password, confirmPassword }
  - rules: FormRules (含密码一致性校验)
  + onSubmit() → authStore.register()
  __ 成功后 router.push('/subjects')
}

class "SubjectListView\n学科列表页" as SubjectListView {
  - subjectStore 学科数据
  + enterSubject(id) → router.push('/subjects/:id')
  __ onMounted: fetchSubjects() 如果列表为空
  __ 卡片网格展示学科
}

class "SubjectDetailView\n学科详情页" as SubjectDetailView {
  - subjectStore / noteStore / pageStore
  - currentPageId 当前选中的笔记页
  + selectPage(id) 切换页面
  + addPage() 新建笔记页
  + createNote() 创建笔记
  + saveCurrentPage() 保存当前页
  __ MarkdownEditor 集成 Vditor 编辑器
  __ 页面标签栏 (page tabs)
  __ 右键菜单 (重命名/删除)
}

class "GraphExplorerView\n知识图谱页" as GraphExplorerView {
  - graphStore 图谱数据
  - showLegend 图例显隐
  - selectedNodeDetail 节点详情
  + viewNode(nodeId) 查看节点笔记
  __ ← 返回按钮
  __ KnowledgeGraph 可视化组件
}

class "ReviewProgressView\n学习进度页" as ReviewProgressView {
  - reviewStore 复习统计
  - noteStore 笔记列表
  + markReview(page) 标记复习
  + undoReview(page) 撤销复习
  __ 统计卡片 (总页数/已复习/完成度/已掌握)
  __ 复习轮次分布柱状图
}

class "SlideShowView\n演示模式页" as SlideShowView {
  + goBack() 返回编辑
  __ 全屏幻灯片渲染
  __ 键盘导航: ← → 翻页, F 全屏, Esc 退出
}

class "NoteEditorView\n笔记编辑器(跳转)" as NoteEditorView {
  __ onMounted: 自动跳转到学科详情
  __ router.replace('/subjects/:subjectId')
}

class "PageEditorView\n页面编辑器" as PageEditorView {
  - pageStore / treeStore
  + attachNode / detachNode 关联知识点
  __ 返回按钮 router.back()
  __ 知识点标签关联
}

class "AdminDashboard\n管理后台首页" as AdminDashboardView {
  __ 系统统计概览
  __ 用户数/学科数/节点数等
}

class "ForbiddenView\n403 禁止访问" as ForbiddenView {
  __ 权限不足提示页
}

class "NotFoundView\n404 未找到" as NotFoundView {
  __ 页面不存在提示
}

' -- 核心组件 --
class "AppSidebar\n侧边栏" as AppSidebar {
  - selectedSubject 当前学科
  - searchText 搜索文本
  + syncFromRoute() 从路由同步状态
  + onSubjectChange(id) 切换学科
  + openAddNodeDialog() 添加知识点弹窗
  + createKnowledgeNode() 创建知识点
  __ 学科下拉选择器
  __ 用户菜单
  __ 搜索框
}

class "KnowledgeTree\n知识树" as KnowledgeTree {
  - treeRef 树组件引用
  + onNodeClick(data) → selectNode + expandNode + 可能导航
  __ el-tree 组件渲染
  __ 节点颜色标识掌握程度
  __ 节点标签 + 笔记页计数
}

class "AppNavbar\n导航栏" as AppNavbar {
  - tabs[] 视图标签(编辑/图谱/演示/进度)
  + onTabClick(key) 切换视图
  + showViewTabs : computed
  __ 面包屑导航 (HomeFilled → 学科 → 节点)
  __ 视图模式切换按钮
}

class "RightPanel\n右侧面板" as RightPanel {
  __ 关联推荐面板
}

' -- Store 层 --
class "authStore\n认证状态" as AuthStore {
  + user, token, loading
  + isAuthenticated, isAdmin : computed
  + login(credentials) 登录请求
  + register(data) 注册请求
  + logout() 退出登录
  + fetchCurrentUser() 获取当前用户信息
}

class "subjectStore\n学科状态" as SubjectStore {
  + subjects[], currentSubjectId, loading
  + currentSubject : computed
  + fetchSubjects() 获取学科列表
  + setCurrentSubject(id) 设置当前学科
  + clearCurrentSubject() 清除
}

class "knowledgeTreeStore\n知识树状态" as KnowledgeTreeStore {
  + treeData[], flatNodeMap, selectedNodeId, expandedKeys[]
  + selectedNode : computed
  + fetchTree(subjectId) 获取树
  + selectNode / expandNode / collapseNode
  + createNode / updateNode / deleteNode
}

class "uiStore\n界面状态" as UiStore {
  + sidebarCollapsed, rightPanelVisible
  + theme ('dark'/'light')
  + viewMode ('edit'/'graph'/'slides'/'progress')
  + toggleSidebar() 切换侧栏收拢
  + setViewMode(mode) 设置视图模式
  + setTheme(theme) 切换主题
}

class "graphStore\n图谱状态" as GraphStore {
  + graphData, selectedNodeId, selectedNode
  + loading
  + fetchGraphData(subjectId) 获取图谱数据
}

class "reviewStore\n复习状态" as ReviewStore {
  + subjectStats, reviews[]
  + loading
  + fetchProgress(subjectId) 获取进度统计
  + recordReview(pageId, round, mastery) 记录复习
}

class "noteStore\n笔记状态" as NoteStore {
  + pages[], currentNote, loading
  + fetchNote(subjectId) 获取笔记
  + createNote / createPage 创建笔记/页面
}

class "pageStore\n页面状态" as PageStore {
  + currentPage, content, attachedNodeIds[]
  + isDirty, saving
  + fetchPage(id) 获取页面内容
  + savePage() 保存页面
  + markDirty() 标记有未保存更改
  + attachNode / detachNode 关联知识节点
}

' -- 关系 --
Router --> RoutesConfig : 注册路由表
Router --> Guards : 注册导航守卫
Guards --> AuthStore : 检查认证状态

AppVue --> AuthLayout : meta.layout='auth'
AppVue --> MainLayout : meta.layout='main'
AppVue ..> RoutesConfig : route.meta.layout

MainLayout --> AppSidebar : 左侧插槽
MainLayout --> AppNavbar : 顶部插槽
MainLayout --> RightPanel : 右侧插槽
MainLayout ..> UiStore : 侧栏宽/面板显隐
MainLayout ..> NoteStore : 页数统计
MainLayout ..> PageStore : 保存状态

AppSidebar --> KnowledgeTree : 知识树渲染
AppSidebar --> SubjectStore : 学科列表
AppSidebar --> KnowledgeTreeStore : 树数据/操作

AppNavbar --> UiStore : 视图模式
AppNavbar --> SubjectStore : 面包屑-学科名
AppNavbar --> KnowledgeTreeStore : 面包屑-节点名
AppNavbar --> AuthStore : 管理员显示
AppNavbar ..> Router : router.push 切换视图

LoginView --> AuthStore : login()
RegisterView --> AuthStore : register()

SubjectListView --> SubjectStore : fetchSubjects
SubjectListView ..> Router : router.push 进学科

SubjectDetailView --> SubjectStore : 当前学科
SubjectDetailView --> NoteStore : 笔记/页面
SubjectDetailView --> PageStore : 内容读写

GraphExplorerView --> GraphStore : 图谱数据
GraphExplorerView --> KnowledgeTreeStore : 节点选中

ReviewProgressView --> ReviewStore : 复习统计
ReviewProgressView --> NoteStore : 页面列表

KnowledgeTree --> KnowledgeTreeStore : 树操作
KnowledgeTree ..> Router : 节点点击跳转

' -- 布局嵌套关系 --
AuthLayout --> LoginView : <router-view>
AuthLayout --> RegisterView : <router-view>
MainLayout --> SubjectListView : <router-view>
MainLayout --> SubjectDetailView : <router-view>
MainLayout --> GraphExplorerView : <router-view>
MainLayout --> ReviewProgressView : <router-view>
MainLayout --> PageEditorView : <router-view>
BlankLayout --> SlideShowView : <router-view>
BlankLayout --> ForbiddenView : <router-view>
BlankLayout --> NotFoundView : <router-view>

@enduml
